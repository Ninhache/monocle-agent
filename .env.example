# monocle-agent configuration — copy to `.env` and fill in.
# Export stays OFF until MONOCLE_API_KEY is set.

# Required to enable export (sent as the `x-api-key` header).
MONOCLE_API_KEY=

# OTLP/HTTP base endpoint. Per-signal paths (/v1/traces, /v1/metrics, /v1/logs)
# are appended internally. Point this at a local collector for testing:
#   MONOCLE_ENDPOINT=http://localhost:4318
MONOCLE_ENDPOINT=https://ingest.monocle.sh

# Deployment environment: development | staging | production.
# Sent as `x-monocle-env` and as the deployment.environment resource attribute.
MONOCLE_ENV=production

# Override service.name / service.version (otherwise taken from the values you
# pass to MonocleConfig::from_env).
# OTEL_SERVICE_NAME=my-service
# MONOCLE_SERVICE_VERSION=1.2.3

# Tracing filter used when set (falls back to the crate's log_filter otherwise).
# RUST_LOG=my_service=debug,info
